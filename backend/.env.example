# Copy to .env for local (non-docker) runs. docker-compose injects its own values.
APP_ENV=dev
LOG_LEVEL=INFO

# Postgres (+ pgvector). Uses the psycopg3 driver.
DATABASE_URL=postgresql+psycopg://publique:publique@localhost:5432/publique

# Redis / RQ
REDIS_URL=redis://localhost:6379/0

# S3-compatible object storage (MinIO in dev, Scaleway/OVH in prod)
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=fr-par
S3_ACCESS_KEY=publique
S3_SECRET_KEY=publique-secret
S3_BUCKET_DCE=publique-dce

# Anthropic — required for M1 Fiche AO extraction. The CDC picks Sonnet for
# classification + structured extraction (cost/quality). Override the models if
# a stronger one is justified for accuracy.
ANTHROPIC_API_KEY=
LLM_MODEL_CLASSIFICATION=claude-sonnet-5
LLM_MODEL_EXTRACTION=claude-sonnet-5
LLM_EFFORT=medium
LLM_MAX_TOKENS=8000

# OCR fallback (Tesseract). A PDF page under OCR_MIN_CHARS of native text is
# re-read via OCR in OCR_LANG.
OCR_LANG=fra
OCR_MIN_CHARS=120
OCR_DPI=300

# Bound the LLM corpus on very large DCE (cost guard).
PIPELINE_MAX_CONTEXT_CHARS=350000

# Basic auth for the internal tool (two users only, per the CDC).
# Comma-separated user:password pairs. Placeholder — change before any deploy.
BASIC_AUTH_USERS=baptiste:changeme,liquid:changeme
